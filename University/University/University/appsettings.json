{
  "ConnectionStrings": {
    //Server tähendab andmebaasi server aadressi, mis vüib olla kohalik (localdb) või kaugserver.
    //DataBase tähendab andmebaasi nime, mida soovite kasutada.
    //Trusted_Connection=True tähendab, et ühendus kasutab windows autentimist ja kasutaja peab olema õigustega windowsi kasutaja.
    //MultipleActiveResultSets=true võimaldab samaaegselt avada mitu andmebaasi päringut ja käsitleda nende tulemusi.
    "UniversityContext": "Server=(localdb)\\mssqllocaldb;Database=UniversityDB;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "AllowedHosts": "*"
  }
